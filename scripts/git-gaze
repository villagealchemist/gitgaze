#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 2 ]; then
  echo "Usage: git gaze <left> <right>" >&2
  exit 1
fi

if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  echo "git gaze must be run inside a Git repository." >&2
  exit 1
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd -- "$script_dir/.." && pwd)"
rust_cli="$project_root/src-tauri/target/debug/git-gaze"
debug_binary="$project_root/src-tauri/target/debug/gitgaze"

if [ -x "$rust_cli" ]; then
  exec "$rust_cli" "$1" "$2"
fi

if [ ! -x "$debug_binary" ]; then
  cat >&2 <<EOF
GitGaze debug binaries were not found.

Build them first with:
  cargo build --bin git-gaze
  pnpm tauri build --debug

For live development with launch args, use:
  pnpm tauri:dev:args --gaze-left "$1" --gaze-right "$2" --gaze-repo "$repo_root"
EOF
  exit 1
fi

exec "$debug_binary" --gaze-left "$1" --gaze-right "$2" --gaze-repo "$repo_root"
